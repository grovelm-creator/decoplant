{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"content_height":100,"background":"alt-background","parallax":false,"show_scrim":true,"scrim_lightness":0}},"rich_text_DX6XeG":{"type":"rich-text","blocks":{"text_QWgQd8":{"type":"text","settings":{"text":"<h1>Bæredygtighed er kernen i alt, vi gør hos DECOPLANT<\/h1><p>Hos <strong>DECOPLANT<\/strong>er bæredygtighed ikke blot et modeord – det er kernen i vores forretningsstrategi.Siden 2019 har vi forpligtet os til at integrere bæredygtige praksisser i alle aspekter af vores virksomhed, hvilket gør os til Danmarks første planteservicevirksomhed, der går \"all-in\" på bæredygtighed<\/p>","font_size":100,"font_type":"body-font","font_style":"none"}}},"block_order":["text_QWgQd8"],"settings":{"text_align":"center","background":"main-background","padding_top":44,"padding_bottom":44}},"media_with_text_7xKT6J":{"type":"media-with-text","blocks":{"heading_fTHgHM":{"type":"heading","settings":{"title":"","font_size":100,"font_type":"heading-font","font_style":"all_caps"}},"text_Mn6tRx":{"type":"text","settings":{"text":"<p><strong>Vi vil være Danmarks grønneste plantevirksomhed <\/strong>Hos DECOPLANT er bæredygtighed ikke en tilføjelse – det er fundamentet for alt, vi gør. Vi arbejder målrettet med grøn omstilling, cirkulær økonomi og ansvarlige løsninger i hele vores værdikæde.<\/p>","font_size":100,"font_type":"body-font","font_style":"none"}},"button_racNMp":{"type":"button","settings":{"button_label":"","button_link":""}}},"block_order":["heading_fTHgHM","text_Mn6tRx","button_racNMp"],"settings":{"image":"shopify:\/\/shop_images\/Decoplant-4.jpg","autoplay_video":true,"image_ratio":"16-9","media_width":780,"vertical_text_align":"top","layout":"left","section_align":"center","overlap_text":true,"image_animation":"none","background":"alt-background-2","frosted_glass":false,"padding_top":44,"padding_bottom":44}},"media_with_text_WNjWgz":{"type":"media-with-text","blocks":{"heading_TiN396":{"type":"heading","settings":{"title":"Vi er nu B Corp-certificeret","font_size":80,"font_type":"heading-font","font_style":"none"}},"text_3Jx8AE":{"type":"text","settings":{"text":"<p>Vi er nu en certificeret B Corporation™ – en del af en global bevægelse af virksomheder, der bruger forretning som en kraft for det gode. Certificeringen bekræfter, at vi lever op til høje standarder for social og miljømæssig bæredygtighed, gennemsigtighed og ansvarlighed.<\/p>","font_size":100,"font_type":"body-font","font_style":"none"}},"button_Yt8cPT":{"type":"button","settings":{"button_label":"","button_link":""}}},"block_order":["heading_TiN396","text_3Jx8AE","button_Yt8cPT"],"settings":{"image":"shopify:\/\/shop_images\/B-Corp-Logo-Tagline-Lockup-Standards-Black-CMYK.jpg","autoplay_video":true,"image_ratio":"16-9","media_width":780,"vertical_text_align":"top","layout":"left","section_align":"left","overlap_text":false,"image_animation":"none","background":"alt-background-2","frosted_glass":false,"padding_top":44,"padding_bottom":44}},"media_with_text_aFqzCP":{"type":"media-with-text","blocks":{"heading_YGickR":{"type":"heading","settings":{"title":"Secondhand-planter ","font_size":99,"font_type":"heading-font","font_style":"none"}},"text_pirNz9":{"type":"text","settings":{"text":"<p>Hos Decoplant giver vi planter nyt liv. Vores udvalg af secondhand-planter består af tidligere erhvervsplanter, som vi har nænsomt plejet og klargjort, så de igen kan bringe liv og grønt til nye omgivelser.<\/p><p>Ved at genbruge planter reducerer vi spild og sparer ressourcer – det er bæredygtighed i praksis. I stedet for at kassere velfungerende planter, sikrer vi, at de får en ny chance, hvilket både gavner miljøet og din virksomheds grønne profil.<\/p><p>Vores secondhand-planter er et bevidst valg for dig, der ønsker at indrette med omtanke. Du får smukke, robuste planter – til en skarp pris og med et lille CO2-aftryk.<\/p>","font_size":100,"font_type":"body-font","font_style":"none"}}},"block_order":["heading_YGickR","text_pirNz9"],"settings":{"image":"shopify:\/\/shop_images\/u9365974648_a_highly_realistic_photo_of_a_group_of_secondhand_32cba8f6-5fe0-4c4f-b251-96d989a422f2_0.png","autoplay_video":true,"image_ratio":"16-9","media_width":780,"vertical_text_align":"top","layout":"left","section_align":"center","overlap_text":true,"image_animation":"none","background":"alt-background-2","frosted_glass":false,"padding_top":44,"padding_bottom":44}},"media_with_text_AQb7rE":{"type":"media-with-text","blocks":{"heading_bnyLkV":{"type":"heading","settings":{"title":"Transparens og dokumentation","font_size":99,"font_type":"heading-font","font_style":"none"}},"text_yHqYa3":{"type":"text","settings":{"text":"<p><strong>Se vores ESG-rapport<\/strong>Vi tror på gennemsigtighed og deler løbende vores fremskridt.<\/p>","font_size":100,"font_type":"body-font","font_style":"none"}},"button_QDwdUn":{"type":"button","settings":{"button_label":"Se seneste ESG RAPORT","button_link":"shopify:\/\/pages\/esg"}}},"block_order":["heading_bnyLkV","text_yHqYa3","button_QDwdUn"],"settings":{"image":"shopify:\/\/shop_images\/Skaermbillede_27-3-2025_93450.jpg","autoplay_video":true,"image_ratio":"16-9","media_width":780,"vertical_text_align":"top","layout":"left","section_align":"center","overlap_text":true,"image_animation":"none","background":"alt-background-2","frosted_glass":false,"padding_top":44,"padding_bottom":44}},"spotlight_MMzWyT":{"type":"spotlight","disabled":true,"settings":{"layout":"layout-a","title":"Vi er nu en certificeret B Corporation™ – en del af en global bevægelse af virksomheder, der bruger forretning som en kraft for det gode. Certificeringen bekræfter, at vi lever op til høje standarder for social og miljømæssig bæredygtighed, gennemsigtighed og ansvarlighed.","accent_title":"","font_size":60,"color_text":"secondary-text-1","image":"shopify:\/\/shop_images\/B-Corp-Logo-Black-RGB.png","link":"","color_1":"#3a3a3e","color_2":"#3a3a3e","color_3":"#3a3a3e","color_4":"#3a3a3e",